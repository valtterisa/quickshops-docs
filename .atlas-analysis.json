  "keyFeatures": [
    "One-click storefront deployment from pre-built templates",
    "AI chat interface to edit and customize your store",
    "Digital products and subscription billing via Stripe",
    "Orders, customers, and analytics dashboard",
    "Headless REST API for external integrations",
    "JavaScript SDK for server-side storefront rendering",
    "MCP server for AI agent access to store data",
    "Discount codes and promotional pricing",
    "Media management for product assets",
    "Telegram integration for store notifications"
  ],
  "publicApiSurface": [
    "GET /v1/products/store",
    "GET /v1/products",
    "GET /v1/products/:productId",
    "GET /v1/cart/:cartId",
    "POST /v1/cart",
    "POST /v1/cart/:cartId/lines",
    "PATCH /v1/cart/:cartId/lines/:productId",
    "DELETE /v1/cart/:cartId/lines/:productId",
    "DELETE /v1/cart/:cartId",
    "POST /v1/checkout/session",
    "POST /v1/subscription/portal",
    "qs.store.get()",
    "qs.products.getAll()",
    "qs.products.getById(productId)",
    "qs.cart.create()",
    "qs.cart.get(cartId)",
    "qs.cart.addLine(cartId, productId, quantity)",
    "qs.cart.updateLine(cartId, productId, quantity)",
    "qs.cart.removeLine(cartId, productId)",
    "qs.cart.clear(cartId)",
    "qs.checkout.createSession(cartId)",
    "qs.subscription.createPortalSession(memberSessionId)"
  ]
